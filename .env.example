# ============ PROVIDERS (ADR-008) ============
# Qwen Cloud is first locally and when deployed; OpenRouter is fallback only.
PROVIDER_ORDER=qwencloud,openrouter

# Dedicated table-scoped Function Compute runtime role. Provision/inspect with
# `python scripts/fc_role.py ensure|inspect`; never put a long-lived AK/SK in FC.
FC_EXECUTION_ROLE_ARN=
# Default Function Compute trigger root used by `deploy/alibaba_proof.py`.
FC_PUBLIC_URL=

# --- Qwen Cloud (Model Studio, Intl/Singapore workspace) — COMPLIANCE PRIMARY ---
# Use a general Model Studio API key; coding-plan keys are not permitted for app backends.
# Production startup rejects blank, whitespace-containing, obvious-placeholder,
# shorter-than-20-character, or lower-than-8-distinct-character provider keys.
# NB: the Alibaba Cloud ACCOUNT needs a payment method (card w/ 3DS+intl, or PayPal).
# SA cards often fail the $1 pre-auth -> use PayPal. See QWEN_CLOUD_INTEGRATION.md.
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# M0 verified qwen3.8-max-preview as unavailable (HTTP 404); use working pairs only.
QWENCLOUD_MODELS=qwen3.7-max,qwen3-max,qwen-plus

# --- OpenRouter — RUNTIME FALLBACK (SA-payment-safe) ---
OPENROUTER_API_KEY=
# M0 verified qwen/qwen3.8-max-preview as unavailable (HTTP 400).
OPENROUTER_MODELS=qwen/qwen3.7-max,qwen/qwen3-max,qwen/qwen-plus

# --- Model roles ---
PRIMARY_MODEL=qwen3.7-max
FAST_MODEL=qwen-flash
OPENROUTER_FAST_MODEL=qwen/qwen3.6-flash
EMBEDDING_MODEL=text-embedding-v4        # Qwen Cloud ONLY (no OpenRouter fallback)
EMBEDDING_DIM=1024

# ============ APP ============
APP_ENV=dev
APP_VERSION=0.1.0
DEPLOYED_ON=local
PORT=8000
# Production startup requires at least 32 characters, no whitespace or obvious
# placeholder text, and at least 8 distinct characters. Validation errors name
# only this variable and never echo its value.
WEBHOOK_SIGNING_SECRET=
# Single-operator application token (ADR-025). Production requires a random
# 32-4096 visible-ASCII value with no whitespace/placeholder form and at least
# 8 distinct characters. The browser keeps it in memory only and discards it on
# reload; never embed it in HTML, URLs, logs, screenshots, or browser storage.
PRAXIS_OPERATOR_TOKEN=
DEDUP_WINDOW_SECONDS=600
MAX_WEBHOOK_BODY_BYTES=262144             # 256 KiB; accepted ADR-012
MAX_APPROVAL_BODY_BYTES=16384             # 16 KiB; accepted ADR-012
MEMORY_BACKEND=tablestore                # tablestore | inmem
MEMORY_SIMILARITY_THRESHOLD=0.80

# Isolated disposable FC restart target (FR-8). Choose the token first, deploy
# the target-only bootstrap manifest, then copy its allowlisted fcapp.run URL
# here before final controller verification/deployment. Final production
# readiness requires both values. Use a random 32-4096 visible-ASCII token with
# at least 8 distinct characters and no whitespace or placeholder form.
PRAXIS_DEMO_TARGET_URL=
PRAXIS_DEMO_TARGET_TOKEN=

# ============ Tablestore (empty when MEMORY_BACKEND=inmem) ============
# Local development uses the instance's Public data endpoint, not the regional
# management endpoint: https://<instance>.ap-southeast-1.ots.aliyuncs.com
TABLESTORE_ENDPOINT=
TABLESTORE_INSTANCE=
# Local dev only — in FC these are injected by the execution role:
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
# Required only when the local credentials are temporary STS credentials. FC
# injects this automatically alongside its temporary role credentials.
ALIBABA_CLOUD_SECURITY_TOKEN=
